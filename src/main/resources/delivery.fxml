<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.deliveryroute.ui.DeliveryController"
            styleClass="root">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
            <padding>
                <Insets top="10" right="16" bottom="10" left="16"/>
            </padding>
            <Label fx:id="deliveryUserLabel" text="Delivery User" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
            <VBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="bellLabel" text="🔔" styleClass="bell-icon" onMouseClicked="#openNotifications"/>
            <Label fx:id="unreadBadgeLabel" text="0" styleClass="badge-unread"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="10" prefWidth="760" styleClass="card">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <Label text="Delivery Orders" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
            <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="Order ID" prefWidth="80"/>
                    <TableColumn fx:id="customerColumn" text="Customer" prefWidth="120"/>
                    <TableColumn fx:id="routeColumn" text="Route" prefWidth="170"/>
                    <TableColumn fx:id="vehicleColumn" text="Vehicle" prefWidth="90"/>
                    <TableColumn fx:id="placedAtColumn" text="Placed At" prefWidth="150"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                    <TableColumn fx:id="actionColumn" text="Action" prefWidth="90"/>
                </columns>
            </TableView>
            <Button fx:id="simulateMovementButton" text="Simulate Movement (+10%)" onAction="#onSimulateMovement" styleClass="btn-primary"/>
            <Label fx:id="trackingStatusLabel" text="Tracking inactive" style="-fx-text-fill: #475569;"/>
        </VBox>
    </left>

    <center>
        <WebView fx:id="mapWebView"/>
    </center>

</BorderPane>
